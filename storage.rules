rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    // Deny all public access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ─── Files Module ──────────────────────────────────────────────
    // Org-scoped file storage: only authenticated users whose auth token
    // orgId matches the path orgId segment may read or write.
    // All file operations are proxied through the Next.js server routes,
    // so the Firebase Admin SDK bypasses these rules — this rule provides
    // defence-in-depth against direct client access.
    match /organizations/{orgId}/files/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.token.orgId == orgId;
    }
  }
}
