rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── API Keys ──────────────────────────────────────────────────
    // Written only by admin SDK (Cloud Functions / server actions).
    // Authenticated users may read their own org's keys for UI display.
    match /api_keys/{keyId} {
      allow read: if request.auth != null
        && resource.data.orgId == request.auth.token.orgId;
      allow write: if false;
    }

    // ─── Store Module ──────────────────────────────────────────────
    function isOrgMember(orgId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    match /organizations/{orgId}/stores/{storeId} {
      allow read, create, update, delete: if isOrgMember(orgId);

      match /documents/{docId} {
        allow read, create, update, delete: if isOrgMember(orgId);
      }
    }

    // ─── Memory Module ─────────────────────────────────────────────
    match /organizations/{orgId}/memories/{memoryId} {
      allow read, create, update, delete: if isOrgMember(orgId);

      match /documents/{docId} {
        allow read, create, update, delete: if isOrgMember(orgId);
      }
    }

    // ─── Files Module ──────────────────────────────────────────────
    match /organizations/{orgId}/files/{fileId} {
      allow read, create, update, delete: if isOrgMember(orgId);
    }

    // ─── Context Module ────────────────────────────────────────────
    match /organizations/{orgId}/contexts/{contextId} {
      // READ: Org member can read any context in their org
      allow read: if isOrgMember(orgId);

      // CREATE: Org member can create context; validate name 1-100 chars, windowSize
      allow create: if isOrgMember(orgId)
        && request.resource.data.orgId == orgId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && (request.resource.data.windowSize == null
            || (request.resource.data.windowSize is number
                && request.resource.data.windowSize > 0))
        && request.resource.data.documentCount == 0;

      // UPDATE: Org member can update name/windowSize; preserve createdBy/createdAt
      allow update: if isOrgMember(orgId)
        && resource.data.orgId == orgId
        && (request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.name.size() <= 100)
        && (request.resource.data.windowSize == null
            || (request.resource.data.windowSize is number
                && request.resource.data.windowSize > 0));

      // DELETE: Org member can delete context
      allow delete: if isOrgMember(orgId)
        && resource.data.orgId == orgId;
    }
  }
}