rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── API Keys ──────────────────────────────────────────────────
    // Written only by admin SDK (Cloud Functions / server actions).
    // Authenticated users may read their own org's keys for UI display.
    match /api_keys/{keyId} {
      allow read: if request.auth != null
        && resource.data.orgId == request.auth.token.orgId;
      allow write: if false;
    }

    // ─── Store Module ──────────────────────────────────────────────
    function isOrgMember(orgId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid));
    }

    match /organizations/{orgId}/stores/{storeId} {
      allow read, create, update, delete: if isOrgMember(orgId);

      match /documents/{docId} {
        allow read, create, update, delete: if isOrgMember(orgId);
      }
    }

    // ─── Memory Module ─────────────────────────────────────────────
    match /organizations/{orgId}/memories/{memoryId} {
      allow read, create, update, delete: if isOrgMember(orgId);

      match /documents/{docId} {
        allow read, create, update, delete: if isOrgMember(orgId);
      }
    }
  }
}