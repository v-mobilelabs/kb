rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── API Keys ──────────────────────────────────────────────────
    // Written only by admin SDK (Cloud Functions / server actions).
    // Authenticated users may read their own org's keys for UI display.
    match /api_keys/{keyId} {
      allow read: if request.auth != null
        && resource.data.orgId == request.auth.token.orgId;
      allow write: if false;
    }

    // ─── Store Module ──────────────────────────────────────────────
    // isOrgMember: checks memberships subcollection (new schema as of module 006)
    function isOrgMember(orgId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(request.auth.uid)).data.deletedAt == null;
    }

    // isOrgAdmin: owner or admin baseRole
    function isOrgAdmin(orgId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(request.auth.uid))
        && get(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(request.auth.uid)).data.deletedAt == null
        && get(/databases/$(database)/documents/organizations/$(orgId)/memberships/$(request.auth.uid)).data.baseRole in ["owner", "admin"];
    }

    match /organizations/{orgId}/stores/{storeId} {
      allow read, create, update, delete: if isOrgMember(orgId);

      match /documents/{docId} {
        allow read, create, update, delete: if isOrgMember(orgId);
      }
    }

    // ─── Memory Module ─────────────────────────────────────────────
    match /organizations/{orgId}/memories/{memoryId} {
      allow read, create, update, delete: if isOrgMember(orgId);

      match /documents/{docId} {
        allow read, create, update, delete: if isOrgMember(orgId);
      }
    }

    // ─── Files Module ──────────────────────────────────────────────
    match /organizations/{orgId}/files/{fileId} {
      allow read, create, update, delete: if isOrgMember(orgId);
    }

    // ─── Context Module ────────────────────────────────────────────
    match /organizations/{orgId}/contexts/{contextId} {
      // READ: Org member can read any context in their org
      allow read: if isOrgMember(orgId);

      // CREATE: Org member can create context; validate name 1-100 chars, windowSize
      allow create: if isOrgMember(orgId)
        && request.resource.data.orgId == orgId
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && (request.resource.data.windowSize == null
            || (request.resource.data.windowSize is number
                && request.resource.data.windowSize > 0))
        && request.resource.data.documentCount == 0;

      // UPDATE: Org member can update name/windowSize; preserve createdBy/createdAt
      allow update: if isOrgMember(orgId)
        && resource.data.orgId == orgId
        && (request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.name.size() <= 100)
        && (request.resource.data.windowSize == null
            || (request.resource.data.windowSize is number
                && request.resource.data.windowSize > 0));

      // DELETE: Org member can delete context
      allow delete: if isOrgMember(orgId)
        && resource.data.orgId == orgId;
    }

    // ─── Users & Organizations Module (006) ────────────────────────
    // Memberships: read only by org members; writes by server (Admin SDK) only
    match /organizations/{orgId}/memberships/{userId} {
      allow read: if isOrgMember(orgId);
      allow write: if false; // server-side only via Admin SDK
    }

    // Org-scoped audit log: read by org admins; append-only (no update/delete) by server
    match /organizations/{orgId}/audits/{auditId} {
      allow read: if isOrgAdmin(orgId);
      allow create: if false; // server-side only via Admin SDK
      allow update, delete: if false; // immutable
    }

    // Deletion tasks: server-side only; no client access
    match /deletionTasks/{taskId} {
      allow read, write: if false; // Admin SDK only (Cloud Functions)
    }
  }
}